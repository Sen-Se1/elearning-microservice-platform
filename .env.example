# App
APP_NAME=Learning Portal
APP_VERSION="1.0.0"
DEBUG=True
LOG_LEVEL=INFO
NODE_ENV=development

# Course Service
COURSE_BACKEND_PORT=8001
COURSE_BACKEND_ENV=development
COURSE_BACKEND_URL=http://localhost:8001
COURSE_SERVICE_URL=http://localhost:8001

# User Service
USER_BACKEND_PORT=8002
USER_BACKEND_ENV=development
USER_BACKEND_URL=http://localhost:8002

# Analytics Service
ANALYTICS_BACKEND_PORT=8003
ANALYTICS_BACKEND_ENV=development
ANALYTICS_BACKEND_URL=http://localhost:8003
ANALYTICS_SERVICE_URL=http://localhost:8003

# AI Tutor Service
AI_TUTOR_BACKEND_PORT=8004
AI_TUTOR_BACKEND_ENV=development
AI_TUTOR_BACKEND_URL=http://localhost:8004

# Learning Portal (Frontend)
NEXT_PUBLIC_USER_SERVICE_URL=http://localhost:8002/api/v1/users
NEXT_PUBLIC_COURSE_SERVICE_URL=http://localhost:8001/api/v1
NEXT_PUBLIC_ANALYTICS_SERVICE_URL=http://localhost:8003
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8004/api/v1/tutor
NEXT_PUBLIC_AI_TUTOR_SERVICE_URL=http://localhost:8004/api/v1/tutor
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:3000

# AI / LLM Configuration
LLM_API_URL=http://localhost:11434/v1
LLM_MODEL=llama3
LLM_API_KEY=ollama

# Integrations
N8N_FEEDBACK_WEBHOOK_URL=http://localhost:5678/webhook-test/feedback

# JWT
JWT_SECRET_KEY=your_jwt_secret_key
JWT_EXPIRE_TIME=199d
JWT_ALGORITHM=HS256

## Database
# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/learning_platform

# PostgreSQL
POSTGRES_URL=postgresql://your_postgres_user:your_postgres_password@localhost:5432/learning_platform
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=learning_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=60

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=courses-media
MINIO_SECURE=False
MINIO_ROOT_USER=your_minio_root_user
MINIO_ROOT_PASSWORD=your_minio_root_password

# Mailer
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password